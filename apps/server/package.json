{
  "name": "@repo/server",
  "type": "module",
  "exports": {
    "./trpc": {
      "types": "./dist/src/trpc/index.d.ts",
      "default": "./src/trpc/index.ts"
    },
    "./rbac/helpers": {
      "types": "./dist/src/services/rbac/helpers.d.ts",
      "default": "./src/services/rbac/helpers.ts"
    }
  },
  "scripts": {
    "dev": "tsx --watch src/index.ts",
    "start": "node dist/index.js",
    "build": "tsup",
    "db:generate": "drizzle-kit generate",
    "trpc-typegen": "tsc -p tsconfig.json --emitDeclarationOnly --declaration --outDir ./dist",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "mastra:studio": "mastra studio --port=3002",
    "check-types": "pnpm trpc-typegen && tsc --noEmit",
    "lint": "eslint ."
  },
  "dependencies": {
    "@mastra/hono": "^1.4.3",
    "server": "^1.0.42",
    "@ai-sdk/groq": "^2.0.0",
    "@better-auth/api-key": "^1.5.6",
    "@hono/node-server": "^1.19.7",
    "@hono/trpc-server": "^0.4.1",
    "@mastra/core": "^1.24.1",
    "@mastra/libsql": "^1.8.0",
    "@mastra/memory": "^1.15.0",
    "@modelcontextprotocol/sdk": "^1.25.1",
    "@t3-oss/env-core": "^0.13.10",
    "@trpc/server": "^11.8.0",
    "@types/nodemailer": "^7.0.5",
    "better-auth": "^1.4.7",
    "cheerio": "^1.1.2",
    "drizzle-orm": "^0.45.1",
    "hono": "^4.11.0",
    "nodemailer": "^7.0.12",
    "pg": "^8.16.3",
    "postgres": "^3.4.7",
    "uuidv7": "^1.1.0",
    "ws": "^8.18.3",
    "zod": "^4.2.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@types/pg": "^8.16.0",
    "drizzle-kit": "^0.31.8",
    "eslint": "^9.39.2",
    "globals": "^16.5.0",
    "mastra": "^1.5.0",
    "tsconfig-paths": "^4.2.0",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.54.0"
  }
}
