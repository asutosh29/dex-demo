{
  "name": "@repo/server",
  "type": "module",
  "exports": {
    "./trpc": {
      "types": "./dist/src/trpc/index.d.ts",
      "default": "./src/trpc/index.ts"
    }
  },
  "scripts": {
    "dev": "tsx src/index.ts",
    "start": "tsx src/index.ts",
    "build": "tsc -p tsconfig.json",
    "db:generate": "drizzle-kit generate",
    "trpc-typegen": "tsc -p tsconfig.json --emitDeclarationOnly --declaration --outDir ./dist",
