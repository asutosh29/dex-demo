    "@modelcontextprotocol/sdk": "^1.25.1",
    "@trpc/server": "^11.8.0",
    "@voltagent/core": "^1.2.21",
    "agents": "^0.3.0",
    "ai": "^6.0.3",
    "better-auth": "^1.4.7",
    "cheerio": "^1.1.2",
    "dotenv": "^17.2.3",
    "drizzle-orm": "^0.45.1",
    "hono": "^4.11.0",
    "pg": "^8.16.3",
    "postgres": "^3.4.7",
    "uuidv7": "^1.1.0",
    "ws": "^8.18.3",
    "zod": "^4.2.1"
  },
  "devDependencies": {
    "@types/pg": "^8.16.0",
    "drizzle-kit": "^0.31.8",
